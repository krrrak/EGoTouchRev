<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <?ifndef BuildOutputDir ?>
    <?define BuildOutputDir = "build" ?>
  <?endif ?>
  <!--
    EGoTouchRev 核心服务安装包
    - UpgradeCode 全局唯一，永不修改，用于覆盖更新旧版本。
    - -arch arm64 由命令行参数设定原生架构。
  -->
  <Package Name="!(loc.ProductName)" Manufacturer="!(loc.Manufacturer)" Version="$(var.BuildVersion)"
           UpgradeCode="434AC770-0762-431A-9ABC-DB2F9DB289AC"
           Scope="perMachine"
           Language="!(loc.Language)">

    <!-- 支持自动覆盖升级：UpgradeCode 不变 + Version 提升 → 自动卸载旧版覆盖安装 -->
    <MajorUpgrade DowngradeErrorMessage="!(loc.DowngradeError)" AllowSameVersionUpgrades="yes" />

    <!-- 安装向导界面：WixUI_InstallDir 提供欢迎页 + 许可协议 + 安装目录 + 进度 + 完成 -->
    <ui:WixUI Id="WixUI_InstallDir" />

    <!-- 许可协议 RTF -->
    <WixVariable Id="WixUILicenseRtf" Value="!(loc.LicenseRtf)" />

    <!-- 安装目录页：用户可自定义安装路径，默认 C:\Program Files\EGoTouchRev -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="EGoTouchRev">
        <Directory Id="CONFIGFOLDER" Name="config" />
      </Directory>
    </StandardDirectory>

    <!-- 通过 CAB 将所有文件打包进单个 MSI -->
    <MediaTemplate EmbedCab="yes" />

    <!-- 核心组件 -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">

      <Component Id="EGoTouchServiceComp" Guid="FCF77309-64AC-4F98-8424-B1D6144D9757">
        <File Id="EGoTouchServiceEXE" Source="$(var.BuildOutputDir)\EGoTouchService.exe" KeyPath="yes" />

        <!-- 由 Windows Installer 原生注册系统服务 -->
        <ServiceInstall
            Id="EGoTouchServiceInstaller"
            Type="ownProcess"
            Name="EGoTouchService"
            DisplayName="!(loc.ServiceDisplayName)"
            Description="!(loc.ServiceDescription)"
            Start="auto"
            Account="LocalSystem"
            ErrorControl="normal" />

        <!-- 控制在安装/卸载时自动启停服务 -->
        <ServiceControl Id="StartWixService" Name="EGoTouchService"
                        Start="install"
                        Stop="both"
                        Remove="uninstall" />
      </Component>

    </ComponentGroup>

    <Feature Id="MainFeature" Title="EGoTouch Core" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>
</Wix>
